{
  "functions": [
    {
      "source": "functions",
      "codebase": "pantryai",
      "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log", "*.local"]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "functions": { "port": 5002 },
    "firestore": { "port": 8081 },
    "storage": { "port": 9200 },
    "ui": { "enabled": true, "port": 4001 }
  }
}
