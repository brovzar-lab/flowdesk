# Firebase config — copy to .env.local and fill in values
# Leave as REPLACE_WITH_VALUE to run in demo mode (no backend needed)
VITE_FIREBASE_API_KEY=REPLACE_WITH_VALUE
VITE_FIREBASE_AUTH_DOMAIN=REPLACE_WITH_VALUE
VITE_FIREBASE_PROJECT_ID=REPLACE_WITH_VALUE
VITE_FIREBASE_STORAGE_BUCKET=REPLACE_WITH_VALUE
VITE_FIREBASE_MESSAGING_SENDER_ID=REPLACE_WITH_VALUE
VITE_FIREBASE_APP_ID=REPLACE_WITH_VALUE

# Set to "true" to use Firebase Emulators locally
VITE_USE_EMULATORS=true
