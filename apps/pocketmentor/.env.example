# PocketMentor Environment Variables
# Copy to .env.local and fill in real values

# Firebase (client-side — safe to expose)
EXPO_PUBLIC_FIREBASE_API_KEY=REPLACE_WITH_VALUE
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=lemon-es-tu-dios.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=lemon-es-tu-dios
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=lemon-es-tu-dios.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=477175602236
EXPO_PUBLIC_FIREBASE_APP_ID=REPLACE_WITH_VALUE

# Cloud Functions base URL (set after deploying functions)
EXPO_PUBLIC_FUNCTIONS_URL=https://us-central1-lemon-es-tu-dios.cloudfunctions.net

# Cloud Function secrets — store in Firebase Secret Manager, NOT here
# OPENAI_API_KEY → stored as Firebase Secret: OPENAI_API_KEY
# ANTHROPIC_API_KEY → stored as Firebase Secret: ANTHROPIC_API_KEY
